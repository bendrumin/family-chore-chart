# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# Required for kid mode (PIN verify) and routine completion without parent login
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# App Configuration
NEXT_PUBLIC_APP_NAME=ChoreStar
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email (Resend) - Required for contact form email notifications
RESEND_API_KEY=your_resend_api_key_here
# Contact form notifications
ADMIN_EMAIL=hi@chorestar.app
# Optional extra emails for /dashboard/admin (bsiegel13@gmail.com always allowed)
# FOUNDER_ADMIN_EMAILS=co-founder@example.com

# Stripe Payments
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
STRIPE_PRICE_MONTHLY=price_your_monthly_price_id_here
STRIPE_PRICE_ANNUAL=price_your_annual_price_id_here
STRIPE_PRICE_LIFETIME=price_your_lifetime_price_id_here

# Rate Limiting (Upstash Redis) - Strongly recommended for production.
# Without it, rate limits are per-instance and reset on every deploy.
# Create a free database at https://console.upstash.com or via the
# Vercel Marketplace (Storage -> Upstash Redis), then copy the REST credentials.
# UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here
# (Vercel KV naming also works: KV_REST_API_URL / KV_REST_API_TOKEN)

# Optional: Analytics
# NEXT_PUBLIC_GA_ID=your_google_analytics_id_here
